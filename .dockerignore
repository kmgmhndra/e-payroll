# Dependencies (akan di-install di dalam Docker)
/vendor
/node_modules

# Build output (akan di-build di dalam Docker)
/public/build
/public/hot

# Environment (jangan masukkan secrets ke image)
.env
.env.backup
.env.production

# Git
.git
.gitattributes
.gitignore

# IDE
.idea
.vscode
.fleet
.zed
.phpactor.json

# Logs & cache
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*
!bootstrap/cache/.gitignore
*.log

# Docker files (jangan exclude docker/ karena Dockerfile butuh isinya)
docker-compose.yml

# Testing
/tests
phpunit.xml
.phpunit.cache
.phpunit.result.cache

# OS
Thumbs.db
.DS_Store

# Misc
README.md
